    {
      "name": "Get User by Id with Valid Id Copy",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// pm.test('it should response 200 status code', () => {",
              "//     pm.expect(pm.response).to.have.status(200);",
              "// });",
              "",
              "// pm.test('response body should have correct property and value', () => {",
              "//     const responseJson = pm.response.json();",
              "//     const userId = pm.environment.get('userId');",
              "//     pm.expect(responseJson.status).to.equal('success');",
              "//     pm.expect(responseJson.data.name).to.equal('John Doe');",
              "// });",
              "",
              "",
              "pm.test('it should response 200 status code', () => {",
              "    pm.expect(pm.response).to.have.status(200);",
              "});",
              "",
              "pm.test('response Content-Type header should have application/json value', () => {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.includes('application/json');",
              "});",
              "",
              "pm.test('response body should be an object', () => {",
              "    const responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.be.an('object');",
              "});",
              "",
              "pm.test('response body should contain correct user profile data', () => {",
              "    const responseJson = pm.response.json();",
              "    ",
              "    // Memastikan status response sukses",
              "    pm.expect(responseJson.status).to.equal('success');",
              "    pm.expect(responseJson.data).to.be.an('object');",
              "    ",
              "    // Memastikan ID yang dikembalikan sama dengan ID yang kita minta di URL",
              "    pm.expect(responseJson.data.id).to.equal(pm.environment.get('userId'));",
              "    ",
              "    // Memastikan data profil penting lainnya ada dan tipe datanya benar",
              "    pm.expect(responseJson.data.name).to.be.a('string');",
              "    pm.expect(responseJson.data.email).to.be.a('string');",
              "    pm.expect(responseJson.data.created_at).to.be.a('string');",
              "    ",
              "    // Keamanan: Memastikan password tidak ikut bocor di dalam response API!",
              "    pm.expect(responseJson.data.password).to.be.undefined;",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
